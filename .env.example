# Google Workspace Admin SDK - Service Account
# Isi dengan path ke file JSON service account yang sudah didownload dari Google Cloud Console
GOOGLE_SERVICE_ACCOUNT_FILE=./service-account.json

# Domain utama Google Workspace Anda (contoh: karyabangsa.sch.id)
GOOGLE_DOMAIN=karyabangsa.sch.id

# Email admin Super Admin di Google Workspace (untuk impersonation)
GOOGLE_ADMIN_EMAIL=admin@karyabangsa.sch.id

# Port server (default: 3000)
PORT=3000

# Password default untuk user baru (wajib ganti sendiri oleh user)
DEFAULT_PASSWORD=KaryaBangsa@2025
