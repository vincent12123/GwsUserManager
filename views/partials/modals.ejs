    </div>
    <div class="modal-body" id="essay-review-body" style="flex:1;padding:0;overflow:hidden;display:flex;flex-direction:column">
      <div class="spinner-wrap"><div class="spinner"></div></div>
    </div>
    <div class="modal-footer">
      <button class="btn btn-ghost" onclick="closeModal('modal-essay-review')">Tutup</button>
    </div>
  </div>
</div>

<!-- MODAL: CBT Sesi -->
<div class="modal-overlay" id="modal-cbt-session">
  <div class="modal" style="max-width:500px">
    <div class="modal-head">
      <div class="modal-title" id="cbt-form-title">Buat Sesi Ujian Baru</div>
      <button class="modal-close" onclick="closeModal('modal-cbt-session')">×</button>
    </div>
    <div class="modal-body">
      <input type="hidden" id="cbt-session-id">
      <div class="form-grid">
        <div>
          <label class="field-label">Nama Ujian <span class="req">*</span></label>
          <input type="text" id="cbt-name" class="field-input" placeholder="Ulangan Harian Web Programming">
        </div>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px">
          <div>
            <label class="field-label">Mata Pelajaran <span class="req">*</span></label>
            <input type="text" id="cbt-mapel" class="field-input" placeholder="Pemrograman Web">
          </div>
          <div>
            <label class="field-label">Kelas <span class="req">*</span></label>
            <input type="text" id="cbt-kelas" class="field-input" placeholder="XI RPL 1">
          </div>
        </div>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px">
          <div>
            <label class="field-label">Durasi Ujian (menit)</label>
            <input type="number" id="cbt-duration" class="field-input" value="90" min="10" max="300">
          </div>
          <div>
            <label class="field-label">Jadwal Mulai</label>
            <input type="datetime-local" id="cbt-scheduled" class="field-input">
          </div>
        </div>
        <div>
          <label class="field-label">Rotasi Token Otomatis</label>
          <select id="cbt-token-interval" class="field-input">
            <option value="0">Permanen (tidak berubah)</option>
            <option value="5">Setiap 5 menit</option>
            <option value="10">Setiap 10 menit</option>
            <option value="15">Setiap 15 menit</option>
            <option value="30">Setiap 30 menit</option>
          </select>
          <div style="font-size:11px;color:var(--muted);margin-top:4px">Token baru muncul otomatis — tampilkan di proyektor</div>
        </div>
        <div>
          <label class="field-label">Hubungkan ke Kelas Classroom</label>
          <select id="cbt-course-select" class="field-input">
            <option value="">-- Tidak terhubung --</option>
          </select>
        </div>
        <div style="padding:10px 12px;background:var(--accent-lt);border:1px solid rgba(26,110,250,.2);border-radius:8px;font-size:12px;color:var(--accent-dk)">
          💡 Token akses 6 karakter akan di-generate otomatis. Bagikan token ini kepada siswa sebelum ujian dimulai.
        </div>
      </div>
    </div>
    <div class="modal-footer">
      <button class="btn btn-ghost" onclick="closeModal('modal-cbt-session')">Batal</button>
      <button class="btn btn-primary" id="cbt-session-save-btn" onclick="saveCBTSession()">💾 Simpan</button>
    </div>
  </div>
</div>

<!-- TOAST -->
<div id="toast-stack"></div>
