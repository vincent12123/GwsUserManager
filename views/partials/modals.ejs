
<!-- MODAL: User Form -->
<div class="modal-overlay" id="modal-user">
  <div class="modal">
    <div class="modal-head">
      <div class="modal-title" id="modal-user-title">Tambah User Baru</div>
      <button class="modal-close" onclick="closeModal('modal-user')">×</button>
    </div>
    <div class="modal-body">
      <div class="form-grid form-grid-2">
        <div>
          <label class="field-label">Nama Depan <span class="req">*</span></label>
          <input type="text" id="u-firstname" class="field-input" placeholder="Budi">
        </div>
        <div>
          <label class="field-label">Nama Belakang <span class="req">*</span></label>
          <input type="text" id="u-lastname" class="field-input" placeholder="Santoso">
        </div>
        <div style="grid-column:1/-1">
          <label class="field-label">Email <span class="req">*</span></label>
          <input type="text" id="u-email" class="field-input" placeholder="budi.santoso@<%= school.SCHOOL_DOMAIN %>">
        </div>
        <div style="grid-column:1/-1">
          <label class="field-label">Password Sementara <span class="req">*</span></label>
          <input type="text" id="u-password" class="field-input" placeholder="Min. 8 karakter">
        </div>
        <div style="grid-column:1/-1">
          <label class="field-label">Org Unit</label>
          <input type="text" id="u-ou" class="field-input" placeholder="/ atau /<%= school.SCHOOL_SHORT_NAME %>/Guru">
        </div>
      </div>
    </div>
    <div class="modal-footer">
      <button class="btn btn-ghost" onclick="closeModal('modal-user')">Batal</button>
      <button class="btn btn-primary" id="modal-user-submit" onclick="submitUser()">Simpan</button>
    </div>
  </div>
</div>

<!-- MODAL: Edit User -->
<div class="modal-overlay" id="modal-edit-user">
  <div class="modal">
    <div class="modal-head">
      <div class="modal-title">✏️ Edit User</div>
      <button class="modal-close" onclick="closeModal('modal-edit-user')">×</button>
    </div>
    <div class="modal-body">
      <input type="hidden" id="edit-original-email">
      <div class="form-grid form-grid-2">
        <div>
          <label class="field-label">Nama Depan</label>
          <input type="text" id="edit-firstname" class="field-input" placeholder="Nama depan">
        </div>
        <div>
          <label class="field-label">Nama Belakang</label>
          <input type="text" id="edit-lastname" class="field-input" placeholder="Nama belakang">
        </div>
        <div style="grid-column:1/-1">
          <label class="field-label">Email Baru <span style="color:var(--muted);font-weight:400">(kosongkan jika tidak diubah)</span></label>
          <input type="text" id="edit-email" class="field-input" placeholder="email.baru@<%= school.SCHOOL_DOMAIN %>">
        </div>
        <div style="grid-column:1/-1">
          <label class="field-label">Org Unit</label>
          <select id="edit-ou" class="field-input">
            <option value="/">/ (Root)</option>
          </select>
        </div>
        <div style="grid-column:1/-1">
          <label class="field-label">Reset Password <span style="color:var(--muted);font-weight:400">(kosongkan jika tidak diubah)</span></label>
          <input type="password" id="edit-password" class="field-input" placeholder="Password baru...">
        </div>
      </div>
    </div>
    <div class="modal-footer">
      <button class="btn btn-ghost" onclick="closeModal('modal-edit-user')">Batal</button>
      <button class="btn btn-primary" id="edit-user-submit" onclick="saveEditUser()">💾 Simpan Perubahan</button>
    </div>
  </div>
</div>

<!-- MODAL: Nonaktifkan Guru -->
<div class="modal-overlay" id="modal-deactivate-teacher">
  <div class="modal" style="max-width:560px">
    <div class="modal-head">
      <div class="modal-title">⛔ Nonaktifkan Guru</div>
      <button class="modal-close" onclick="closeModal('modal-deactivate-teacher')">×</button>
    </div>
    <div class="modal-body">

      <!-- Pilih guru -->
      <div style="margin-bottom:14px">
        <label class="field-label">Guru yang akan dinonaktifkan <span class="req">*</span></label>
        <div class="ac-wrap">
          <input type="text" id="dt-teacher-search" class="field-input"
            placeholder="Ketik nama guru..." oninput="dtTeacherSearch(this)">
          <div id="dt-teacher-suggest" class="ac-box"></div>
        </div>
        <div class="selected-indicator" id="dt-teacher-selected">
          <span>👤</span><span id="dt-teacher-text"></span>
          <button onclick="dtClearTeacher()">×</button>
        </div>
        <input type="hidden" id="dt-teacher-email">
      </div>

      <!-- Tujuan transfer Drive -->
      <div style="margin-bottom:14px">
        <label class="field-label">Transfer Drive ke <span class="req">*</span></label>
        <div class="ac-wrap">
          <input type="text" id="dt-target-search" class="field-input"
            placeholder="Ketik nama penerima..." oninput="dtTargetSearch(this)">
          <div id="dt-target-suggest" class="ac-box"></div>
        </div>
        <div class="selected-indicator" id="dt-target-selected">
          <span>📁</span><span id="dt-target-text"></span>
          <button onclick="dtClearTarget()">×</button>
        </div>
        <input type="hidden" id="dt-target-email">
        <div style="font-size:11px;color:var(--muted);margin-top:4px">
          Biasanya ke <a href="/cdn-cgi/l/email-protection" class="__cf_email__" data-cfemail="2f5c5a444e5d4b466f444e5d564e4d4e41485c4e015c4c4701464b">[email&#160;protected]</a>
        </div>
      </div>

      <!-- Opsi tambahan -->
      <div style="margin-bottom:14px;padding:12px 14px;background:var(--surface2);border:1px solid var(--border);border-radius:8px">
        <label style="display:flex;align-items:center;gap:8px;cursor:pointer;font-size:13px">
          <input type="checkbox" id="dt-transfer-calendar" checked>
          Transfer Calendar juga
        </label>
      </div>

      <!-- Alur yang akan dijalankan -->
      <div style="padding:12px 14px;background:var(--accent-lt);border:1px solid rgba(26,110,250,.2);border-radius:8px;font-size:12px;color:var(--accent-dk);line-height:2">
        Langkah yang akan dijalankan otomatis:<br>
        <strong>1.</strong> Suspend akun — guru tidak bisa login<br>
        <strong>2.</strong> Transfer Drive → ke akun tujuan<br>
        <strong>3.</strong> Archive akun — lisensi dibebaskan
      </div>

    </div>
    <div class="modal-footer">
      <button class="btn btn-ghost" onclick="closeModal('modal-deactivate-teacher')">Batal</button>
      <button class="btn btn-primary" id="dt-submit-btn" onclick="confirmDeactivateTeacher()"
        style="background:#7C3AED" disabled>
        ⛔ Nonaktifkan Guru
      </button>
    </div>
  </div>
</div>

<!-- MODAL: Hasil Nonaktifkan Guru -->
<div class="modal-overlay" id="modal-deactivate-result">
  <div class="modal" style="max-width:500px">
    <div class="modal-head">
      <div class="modal-title" id="dt-result-title">Hasil Proses</div>
      <button class="modal-close" onclick="closeModal('modal-deactivate-result')">×</button>
    </div>
    <div class="modal-body" id="dt-result-body"></div>
    <div class="modal-footer">
      <button class="btn btn-primary" onclick="closeModal('modal-deactivate-result');loadUsers()">OK & Refresh</button>
    </div>
  </div>
</div>

<!-- MODAL: Confirm Delete -->
<div class="modal-overlay" id="modal-confirm">
  <div class="modal">
    <div class="modal-head">
      <div class="modal-title" id="confirm-title">Konfirmasi Hapus</div>
      <button class="modal-close" onclick="closeModal('modal-confirm')">×</button>
    </div>
    <div class="modal-body">
      <p id="confirm-msg" style="font-size:13.5px;line-height:1.6;color:var(--muted)"></p>
    </div>
    <div class="modal-footer">
      <button class="btn btn-ghost" onclick="closeModal('modal-confirm')">Batal</button>
      <button class="btn btn-danger" id="confirm-ok">Hapus</button>
    </div>
  </div>
</div>

<!-- MODAL: Bulk Delete -->
<div class="modal-overlay" id="modal-bulk-delete">
  <div class="modal" style="max-width:560px">
    <div class="modal-head">
      <div class="modal-title">🗑 Bulk Hapus User</div>
      <button class="modal-close" onclick="closeModal('modal-bulk-delete')">×</button>
    </div>
    <div class="modal-body">

      <!-- Search autocomplete -->
      <div style="margin-bottom:14px">
        <label class="field-label">Cari & Pilih User</label>
        <div class="ac-wrap">
          <input type="text" id="bd-search" class="field-input"
            placeholder="Ketik nama atau email user..."
            oninput="bdSearch(this)">
          <div id="bd-suggest" class="ac-box"></div>
        </div>
        <div style="font-size:11px;color:var(--muted);margin-top:5px">
          Ketik min. 2 karakter — cari dari daftar user yang sudah dimuat
        </div>
      </div>

      <!-- Selected tags -->
      <div style="margin-bottom:4px">
        <label class="field-label">User yang akan dihapus
          <span id="bd-count-label" style="color:var(--red);font-weight:800"></span>
        </label>
      </div>
      <div id="bd-tags" style="
        min-height:60px; max-height:200px; overflow-y:auto;
        border:1.5px solid var(--border); border-radius:8px;
        padding:8px; display:flex; flex-wrap:wrap; gap:6px;
        background:var(--surface2)">
        <span id="bd-empty-hint" style="color:var(--muted);font-size:12px;padding:4px">
          Belum ada user dipilih...
        </span>
      </div>

      <!-- Warning box -->
      <div style="
        margin-top:14px; padding:12px 14px;
        background:var(--red-lt); border:1px solid rgba(220,38,38,.2);
        border-radius:8px; font-size:12px; color:var(--red); line-height:1.6">
        ⚠️ <strong>Perhatian:</strong> User yang dihapus tidak bisa dikembalikan.
        Semua data, email, dan file Drive milik user tersebut akan hilang permanen.
      </div>

    </div>
    <div class="modal-footer">
      <button class="btn btn-ghost" onclick="closeModal('modal-bulk-delete')">Batal</button>
      <button class="btn btn-ghost" onclick="bdClearAll()" style="margin-right:auto">
        ✕ Hapus Semua Pilihan
      </button>
      <button class="btn btn-danger" id="bd-confirm-btn" onclick="confirmBulkDelete()" disabled>
        🗑 Hapus <span id="bd-btn-count">0</span> User
      </button>
    </div>
  </div>
</div>

<!-- MODAL: Bulk Pindah Org Unit -->
<div class="modal-overlay" id="modal-bulk-move-ou">
  <div class="modal" style="max-width:580px">
    <div class="modal-head">
      <div class="modal-title">📂 Bulk Pindah Org Unit</div>
      <button class="modal-close" onclick="closeModal('modal-bulk-move-ou')">×</button>
    </div>
    <div class="modal-body">

      <!-- Mode pilih -->
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:16px">
        <button id="bmou-mode-ou" onclick="bmouSetMode('ou')"
          class="btn btn-primary" style="justify-content:center">
          🏢 Pilih dari Org Unit
        </button>
        <button id="bmou-mode-tag" onclick="bmouSetMode('tag')"
          class="btn btn-ghost" style="justify-content:center">
          🔍 Cari Satu per Satu
        </button>
      </div>

      <!-- Mode: pilih dari OU -->
      <div id="bmou-panel-ou">
        <label class="field-label">Pilih Org Unit Asal</label>
        <select id="bmou-ou-source" class="field-input" style="margin-bottom:8px" onchange="bmouLoadFromOU()">
          <option value="">-- Pilih Org Unit --</option>
        </select>
        <div id="bmou-ou-preview" style="font-size:12px;color:var(--muted);min-height:20px"></div>
      </div>

      <!-- Mode: tag-based search -->
      <div id="bmou-panel-tag" style="display:none">
        <label class="field-label">Cari & Pilih User</label>
        <div class="ac-wrap">
          <input type="text" id="bmou-search" class="field-input"
            placeholder="Ketik nama atau email..." oninput="bmouSearch(this)">
          <div id="bmou-suggest" class="ac-box"></div>
        </div>
        <div style="font-size:11px;color:var(--muted);margin-top:5px">Ketik min. 2 karakter</div>
      </div>

      <!-- Selected -->
      <div style="margin-top:14px;margin-bottom:4px">
        <label class="field-label">User yang akan dipindah
          <span id="bmou-count-label" style="color:var(--amber);font-weight:800"></span>
        </label>
      </div>
      <div id="bmou-tags" style="min-height:50px;max-height:180px;overflow-y:auto;
        border:1.5px solid var(--border);border-radius:8px;padding:8px;
        display:flex;flex-wrap:wrap;gap:6px;background:var(--surface2);margin-bottom:14px">
        <span style="color:var(--muted);font-size:12px;padding:4px">Belum ada user dipilih...</span>
      </div>

      <!-- OU tujuan -->
      <div>
        <label class="field-label">Org Unit Tujuan <span class="req">*</span></label>
        <select id="bmou-target" class="field-input">
          <option value="">-- Pilih Org Unit Tujuan --</option>
        </select>
      </div>
      <div style="margin-top:10px;padding:10px 12px;background:var(--amber-lt);
        border:1px solid rgba(217,119,6,.2);border-radius:8px;font-size:12px;color:var(--amber)">
        ⚠️ User akan dipindahkan dari org unit saat ini ke org unit yang dipilih.
      </div>
    </div>
    <div class="modal-footer">
      <button class="btn btn-ghost" onclick="closeModal('modal-bulk-move-ou')">Batal</button>
      <button class="btn btn-ghost" onclick="bmouClearAll()" style="margin-right:auto">✕ Reset</button>
      <button class="btn btn-primary" id="bmou-confirm-btn" onclick="executeBulkMoveOU()" disabled>
        📂 Pindah <span id="bmou-btn-count">0</span> User
      </button>
    </div>
  </div>
</div>

<!-- MODAL: Bulk Ganti Lisensi -->
<div class="modal-overlay" id="modal-bulk-license">
  <div class="modal" style="max-width:580px">
    <div class="modal-head">
      <div class="modal-title">🔖 Bulk Ganti Lisensi</div>
      <button class="modal-close" onclick="closeModal('modal-bulk-license')">×</button>
    </div>
    <div class="modal-body">

      <!-- Mode pilih -->
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:16px">
        <button id="bl-mode-ou" onclick="blSetMode('ou')"
          class="btn btn-primary" style="justify-content:center">
          🏢 Pilih dari Org Unit
        </button>
        <button id="bl-mode-tag" onclick="blSetMode('tag')"
          class="btn btn-ghost" style="justify-content:center">
          🔍 Cari Satu per Satu
        </button>
      </div>

      <!-- Mode: pilih dari OU -->
      <div id="bl-panel-ou">
        <label class="field-label">Pilih Org Unit</label>
        <select id="bl-ou-source" class="field-input" style="margin-bottom:8px" onchange="blLoadFromOU()">
          <option value="">-- Pilih Org Unit --</option>
        </select>
        <div id="bl-ou-preview" style="font-size:12px;color:var(--muted);min-height:20px"></div>
      </div>

      <!-- Mode: tag-based search -->
      <div id="bl-panel-tag" style="display:none">
        <label class="field-label">Cari & Pilih User</label>
        <div class="ac-wrap">
          <input type="text" id="bl-search" class="field-input"
            placeholder="Ketik nama atau email..." oninput="blSearch(this)">
          <div id="bl-suggest" class="ac-box"></div>
        </div>
        <div style="font-size:11px;color:var(--muted);margin-top:5px">Ketik min. 2 karakter</div>
      </div>

      <!-- Selected tags / count -->
      <div style="margin-top:14px;margin-bottom:4px">
        <label class="field-label">User yang akan diproses
          <span id="bl-count-label" style="color:var(--accent);font-weight:800"></span>
        </label>
      </div>
      <div id="bl-tags" style="min-height:50px;max-height:180px;overflow-y:auto;
        border:1.5px solid var(--border);border-radius:8px;padding:8px;
        display:flex;flex-wrap:wrap;gap:6px;background:var(--surface2);margin-bottom:14px">
        <span style="color:var(--muted);font-size:12px;padding:4px">Belum ada user dipilih...</span>
      </div>

      <!-- Lisensi tujuan -->
      <div>
        <label class="field-label">Lisensi Tujuan <span class="req">*</span></label>
        <select id="bl-target" class="field-input">
          <option value="">-- Pilih Lisensi --</option>
          <option value="archived">Archived User — tidak bisa login, data tersimpan (Gratis)</option>
          <option value="active">Education Fundamentals — kembalikan ke aktif penuh</option>
        </select>
        <div style="font-size:11px;color:var(--muted);margin-top:6px">
          ℹ️ Gmail Only belum didukung via API — gunakan Admin Console untuk saat ini.
        </div>
      </div>

      <div style="margin-top:10px;padding:10px 12px;background:var(--accent-lt);
        border:1px solid rgba(26,110,250,.2);border-radius:8px;font-size:12px;color:var(--accent-dk)">
        ℹ️ Semua lisensi di atas <strong>gratis</strong> untuk Education Fundamentals.
        Gunakan <strong>Archived</strong> untuk alumni/guru yang sudah tidak aktif.
      </div>
    </div>
    <div class="modal-footer">
      <button class="btn btn-ghost" onclick="closeModal('modal-bulk-license')">Batal</button>
      <button class="btn btn-ghost" onclick="blClearAll()" style="margin-right:auto">✕ Reset</button>
      <button class="btn btn-primary" id="bl-confirm-btn" onclick="confirmBulkLicense()" disabled>
        🔖 Ganti Lisensi <span id="bl-btn-count">0</span> User
      </button>
    </div>
  </div>
</div>

