  <div class="modal" style="max-width:820px;width:96vw;max-height:92vh;display:flex;flex-direction:column">
    <div class="modal-head">
      <div style="display:flex;flex-direction:column;gap:2px">
        <div class="modal-title" id="modal-essay-title">Nilai Essay</div>
        <div style="font-size:11px;color:var(--muted)">Mode A — nilai per soal · semua siswa tampil sekaligus</div>
      </div>
      <div style="display:flex;align-items:center;gap:8px;margin-left:auto">
