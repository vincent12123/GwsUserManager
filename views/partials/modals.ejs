<!-- MODAL: Buat Pengumuman (1 kelas) -->
<div class="modal-overlay" id="modal-new-announcement">
  <div class="modal" style="max-width:520px">
    <div class="modal-head">
      <div class="modal-title">📢 Buat Pengumuman</div>
      <button class="modal-close" onclick="closeModal('modal-new-announcement')">×</button>
    </div>
    <div class="modal-body">
      <div style="font-size:12px;color:var(--muted);margin-bottom:12px">
        Kelas: <strong id="ann-modal-course-name">-</strong>
      </div>
      <div style="margin-bottom:12px">
        <label class="field-label">Teks Pengumuman <span class="req">*</span></label>
        <textarea id="ann-text" class="field-input" rows="5" placeholder="Tulis pengumuman..."></textarea>
      </div>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:12px">
        <div>
          <label class="field-label">Status</label>
          <select id="ann-state" class="field-input">
            <option value="PUBLISHED">Publikasikan sekarang</option>
            <option value="DRAFT">Simpan sebagai draft</option>
            <option value="SCHEDULED">Jadwalkan</option>
          </select>
        </div>
        <div id="ann-schedule-wrap" style="display:none">
          <label class="field-label">Jadwal Kirim</label>
          <input type="datetime-local" id="ann-schedule-time" class="field-input">
        </div>
      </div>
      <div style="padding:10px 12px;background:var(--accent-lt);border:1px solid rgba(26,110,250,.2);border-radius:8px;font-size:12px;color:var(--accent-dk)">
        💡 Gunakan tombol <strong>📢 Broadcast</strong> di toolbar untuk kirim ke banyak kelas sekaligus.
      </div>
    </div>
    <div class="modal-footer">
      <button class="btn btn-ghost" onclick="closeModal('modal-new-announcement')">Batal</button>
      <button class="btn btn-primary" id="ann-submit-btn" onclick="submitAnnouncement()">📢 Kirim</button>
    </div>
  </div>
</div>

<!-- MODAL: Broadcast Pengumuman (banyak kelas) -->
<div class="modal-overlay" id="modal-broadcast">
  <div class="modal" style="max-width:560px">
    <div class="modal-head">
      <div class="modal-title">📡 Broadcast Pengumuman</div>
      <button class="modal-close" onclick="closeModal('modal-broadcast')">×</button>
    </div>
    <div class="modal-body">
      <div style="margin-bottom:12px">
        <label class="field-label">Teks Pengumuman <span class="req">*</span></label>
        <textarea id="bc-text" class="field-input" rows="4" placeholder="Tulis pengumuman..."></textarea>
      </div>
      <div style="margin-bottom:12px">
        <label class="field-label">Kirim ke Kelas <span class="req">*</span></label>
        <div style="max-height:200px;overflow-y:auto;border:1.5px solid var(--border);border-radius:8px;background:var(--surface2)" id="bc-course-list">
          <div style="padding:12px;font-size:12px;color:var(--muted)">Memuat daftar kelas...</div>
        </div>
        <div style="display:flex;gap:8px;margin-top:6px">
          <button class="btn btn-ghost" style="font-size:11px;padding:4px 10px" onclick="bcSelectAll()">✓ Semua</button>
          <button class="btn btn-ghost" style="font-size:11px;padding:4px 10px" onclick="bcClearAll()">✕ Bersihkan</button>
          <span id="bc-selected-count" style="font-size:11px;color:var(--muted);align-self:center">0 kelas dipilih</span>
        </div>
      </div>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px">
        <div>
          <label class="field-label">Status</label>
          <select id="bc-state" class="field-input">
            <option value="PUBLISHED">Publikasikan sekarang</option>
            <option value="DRAFT">Draft</option>
            <option value="SCHEDULED">Jadwalkan</option>
          </select>
        </div>
        <div id="bc-schedule-wrap" style="display:none">
          <label class="field-label">Jadwal Kirim</label>
          <input type="datetime-local" id="bc-schedule-time" class="field-input">
        </div>
      </div>
    </div>
    <div class="modal-footer">
      <button class="btn btn-ghost" onclick="closeModal('modal-broadcast')">Batal</button>
      <button class="btn btn-primary" id="bc-submit-btn" onclick="submitBroadcast()">📡 Broadcast</button>
    </div>
  </div>
</div>

<!-- MODAL: Buat Tugas -->
<div class="modal-overlay" id="modal-new-coursework">
  <div class="modal" style="max-width:540px">
    <div class="modal-head">
      <div class="modal-title">📝 Buat Tugas</div>
      <button class="modal-close" onclick="closeModal('modal-new-coursework')">×</button>
    </div>
    <div class="modal-body">
      <div style="font-size:12px;color:var(--muted);margin-bottom:12px">
        Kelas: <strong id="cw-modal-course-name">-</strong>
      </div>
      <div class="form-grid">
        <div>
          <label class="field-label">Judul Tugas <span class="req">*</span></label>
          <input type="text" id="cw-title" class="field-input" placeholder="Judul tugas...">
        </div>
        <div>
          <label class="field-label">Deskripsi</label>
          <textarea id="cw-desc" class="field-input" rows="3" placeholder="Instruksi tugas (opsional)..."></textarea>
        </div>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px">
          <div>
            <label class="field-label">Tipe Tugas</label>
            <select id="cw-type" class="field-input" onchange="toggleQuizFields()">
              <option value="ASSIGNMENT">Tugas biasa</option>
              <option value="SHORT_ANSWER_QUESTION">Jawaban singkat</option>
              <option value="MULTIPLE_CHOICE_QUESTION">Pilihan ganda</option>
            </select>
          </div>
          <div>
            <label class="field-label">Nilai Maksimal</label>
            <input type="number" id="cw-maxpoints" class="field-input" value="100" min="0" max="1000">
          </div>
        </div>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px">
          <div>
            <label class="field-label">Deadline</label>
            <input type="date" id="cw-due-date" class="field-input">
          </div>
          <div>
            <label class="field-label">Jam Deadline</label>
            <input type="time" id="cw-due-time" class="field-input" value="23:59">
          </div>
        </div>
        <div id="cw-drive-wrap">
          <label class="field-label">Lampiran Drive <span style="color:var(--muted);font-weight:400">(ID file Google Drive)</span></label>
          <input type="text" id="cw-drive-id" class="field-input" placeholder="ID file dari URL Drive...">
          <div style="font-size:11px;color:var(--muted);margin-top:4px">
            Ambil dari URL: drive.google.com/file/d/<strong>ID_FILE</strong>/view
          </div>
        </div>
        <div id="cw-choices-wrap" style="display:none">
          <label class="field-label">Pilihan Jawaban <span class="req">*</span> <span style="color:var(--muted);font-weight:400">(minimal 2)</span></label>
          <div id="cw-choices-list">
            <div class="cw-choice-row" style="display:flex;gap:8px;margin-bottom:6px">
              <input type="text" class="field-input cw-choice-input" placeholder="Pilihan A...">
              <button onclick="removeCWChoice(this)" style="background:none;border:none;cursor:pointer;color:var(--red);font-size:18px;padding:0 4px">×</button>
            </div>
            <div class="cw-choice-row" style="display:flex;gap:8px;margin-bottom:6px">
              <input type="text" class="field-input cw-choice-input" placeholder="Pilihan B...">
              <button onclick="removeCWChoice(this)" style="background:none;border:none;cursor:pointer;color:var(--red);font-size:18px;padding:0 4px">×</button>
            </div>
          </div>
          <button onclick="addCWChoice()" class="btn btn-ghost" style="font-size:12px;padding:4px 10px;margin-top:2px">+ Tambah Pilihan</button>
        </div>
        <div>
          <label class="field-label">Status</label>
          <select id="cw-state" class="field-input">
            <option value="PUBLISHED">Publikasikan sekarang</option>
            <option value="DRAFT">Simpan sebagai draft</option>
          </select>
        </div>
        <div>
          <label class="field-label">Topik</label>
          <select id="cw-topic" class="field-input">
            <option value="">-- Tanpa Topik --</option>
          </select>
        </div>
      </div>
    </div>
    <div class="modal-footer">
      <button class="btn btn-ghost" onclick="closeModal('modal-new-coursework')">Batal</button>
      <button class="btn btn-primary" id="cw-submit-btn" onclick="submitCoursework()">📝 Buat Tugas</button>
    </div>
  </div>
</div>

<!-- MODAL: Submissions per Tugas -->
<div class="modal-overlay" id="modal-submissions">
  <div class="modal" style="max-width:680px">
    <div class="modal-head">
      <div>
        <div class="modal-title">📋 Submissions — <span id="sub-work-title">-</span></div>
        <div style="font-size:12px;color:var(--muted);margin-top:2px" id="sub-stats">-</div>
      </div>
      <button class="modal-close" onclick="closeModal('modal-submissions')">×</button>
    </div>
    <div class="modal-body" style="padding:0">
      <table style="width:100%;border-collapse:collapse">
        <thead><tr>
          <th style="padding:10px 16px;text-align:left;font-size:10px;font-weight:700;color:var(--muted);text-transform:uppercase;background:var(--surface2);border-bottom:1px solid var(--border)">Siswa</th>
          <th style="padding:10px 16px;text-align:center;font-size:10px;font-weight:700;color:var(--muted);text-transform:uppercase;background:var(--surface2);border-bottom:1px solid var(--border)">Status</th>
          <th style="padding:10px 16px;text-align:center;font-size:10px;font-weight:700;color:var(--muted);text-transform:uppercase;background:var(--surface2);border-bottom:1px solid var(--border)">Terlambat</th>
          <th style="padding:10px 16px;text-align:center;font-size:10px;font-weight:700;color:var(--muted);text-transform:uppercase;background:var(--surface2);border-bottom:1px solid var(--border)">Nilai</th>
          <th style="padding:10px 16px;text-align:center;font-size:10px;font-weight:700;color:var(--muted);text-transform:uppercase;background:var(--surface2);border-bottom:1px solid var(--border)">Aksi</th>
        </tr></thead>
        <tbody id="sub-tbody"></tbody>
      </table>
    </div>
    <div class="modal-footer">
      <button class="btn btn-ghost" onclick="closeModal('modal-submissions')">Tutup</button>
    </div>
  </div>
</div>

<!-- MODAL: Input Nilai -->
<div class="modal-overlay" id="modal-grade-input">
  <div class="modal" style="max-width:380px">
    <div class="modal-head">
      <div class="modal-title">✏️ Input Nilai</div>
      <button class="modal-close" onclick="closeModal('modal-grade-input')">×</button>
    </div>
    <div class="modal-body">
      <div style="font-size:13px;margin-bottom:14px">
        Siswa: <strong id="grade-student-name">-</strong>
      </div>
      <input type="hidden" id="grade-sub-id">
      <input type="hidden" id="grade-course-id">
      <input type="hidden" id="grade-work-id">
      <div>
        <label class="field-label">Nilai <span class="req">*</span> <span id="grade-max-label" style="color:var(--muted);font-weight:400"></span></label>
        <input type="number" id="grade-value" class="field-input" min="0" placeholder="0 - 100">
      </div>
      <div style="margin-top:10px">
        <label style="display:flex;align-items:center;gap:8px;cursor:pointer;font-size:13px">
          <input type="checkbox" id="grade-return" checked>
          Return ke siswa setelah dinilai (siswa bisa lihat nilainya)
        </label>
      </div>
    </div>
    <div class="modal-footer">
      <button class="btn btn-ghost" onclick="closeModal('modal-grade-input')">Batal</button>
      <button class="btn btn-primary" id="grade-submit-btn" onclick="submitGrade()">💾 Simpan Nilai</button>
    </div>
  </div>
</div>

<!-- MODAL: Kelola Topik -->
<div class="modal-overlay" id="modal-topics">
  <div class="modal" style="max-width:480px">
    <div class="modal-head">
      <div class="modal-title">🏷️ Topik — <span id="topic-course-name">-</span></div>
      <button class="modal-close" onclick="closeModal('modal-topics')">×</button>
    </div>
    <div class="modal-body">
      <!-- Form tambah topik -->
      <div style="display:flex;gap:8px;margin-bottom:14px">
        <input type="text" id="new-topic-name" class="field-input" placeholder="Nama topik baru..." style="flex:1">
        <button class="btn btn-primary" onclick="submitTopic()">+ Tambah</button>
      </div>
      <!-- Daftar topik -->
      <div id="topics-list">
        <div class="spinner-wrap"><div class="spinner"></div></div>
      </div>
    </div>
    <div class="modal-footer">
      <button class="btn btn-ghost" onclick="closeModal('modal-topics')">Tutup</button>
    </div>
  </div>
</div>

<!-- MODAL: Import Soal dari JSON MCP -->
<div class="modal-overlay" id="modal-import-soal">
  <div class="modal" style="max-width:640px">
    <div class="modal-head">
      <div class="modal-title">📋 Import Soal dari JSON MCP</div>
      <button class="modal-close" onclick="closeModal('modal-import-soal')">×</button>
    </div>
    <div class="modal-body">

      <!-- Step 1: Upload/Paste JSON -->
      <div id="import-step-1">
        <div style="margin-bottom:12px">
          <label class="field-label">Upload file JSON</label>
          <div style="display:flex;gap:8px">
            <input type="file" id="soal-file" accept=".json" class="field-input"
              onchange="loadSoalFile(this)" style="flex:1">
          </div>
        </div>
        <div style="text-align:center;color:var(--muted);font-size:12px;margin:8px 0">— atau paste JSON langsung —</div>
        <div>
          <textarea id="soal-json-text" class="field-input" rows="6"
            placeholder='{"meta": {...}, "soal": [...]}'
            style="font-family:var(--mono);font-size:11.5px"></textarea>
        </div>
        <div style="margin-top:10px;display:flex;justify-content:flex-end">
          <button class="btn btn-primary" onclick="previewSoal()">🔍 Preview Soal</button>
        </div>
      </div>

      <!-- Step 2: Preview -->
      <div id="import-step-2" style="display:none">
        <!-- Meta info -->
        <div id="soal-meta-box" style="padding:12px 14px;background:var(--accent-lt);border:1px solid rgba(26,110,250,.2);border-radius:8px;margin-bottom:14px;font-size:12.5px"></div>

        <!-- Daftar soal -->
        <div style="max-height:220px;overflow-y:auto;border:1.5px solid var(--border);border-radius:8px;margin-bottom:14px">
          <table style="width:100%;border-collapse:collapse" id="soal-preview-table">
            <thead><tr>
              <th style="padding:8px 12px;text-align:left;font-size:10px;font-weight:700;color:var(--muted);text-transform:uppercase;background:var(--surface2);border-bottom:1px solid var(--border)">No</th>
              <th style="padding:8px 12px;text-align:left;font-size:10px;font-weight:700;color:var(--muted);text-transform:uppercase;background:var(--surface2);border-bottom:1px solid var(--border)">Tipe</th>
              <th style="padding:8px 12px;text-align:left;font-size:10px;font-weight:700;color:var(--muted);text-transform:uppercase;background:var(--surface2);border-bottom:1px solid var(--border)">Soal</th>
              <th style="padding:8px 12px;text-align:center;font-size:10px;font-weight:700;color:var(--muted);text-transform:uppercase;background:var(--surface2);border-bottom:1px solid var(--border)">Bobot</th>
              <th style="padding:8px 12px;text-align:center;font-size:10px;font-weight:700;color:var(--muted);text-transform:uppercase;background:var(--surface2);border-bottom:1px solid var(--border)">Kunci</th>
            </tr></thead>
            <tbody id="soal-preview-tbody"></tbody>
          </table>
        </div>

        <!-- Opsi kelas & deadline -->
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:10px">
          <div style="grid-column:1/-1">
            <label class="field-label">Lampirkan ke Kelas <span style="color:var(--muted);font-weight:400">(opsional)</span></label>
            <select id="soal-course-id" class="field-input">
              <option value="">-- Tidak dilampirkan (hanya buat Form) --</option>
            </select>
          </div>
          <div>
            <label class="field-label">Status Tugas</label>
            <select id="soal-state" class="field-input" onchange="toggleSoalSchedule()">
              <option value="PUBLISHED">Publikasikan sekarang</option>
              <option value="DRAFT">Simpan sebagai draft</option>
              <option value="SCHEDULED">Jadwalkan rilis</option>
            </select>
          </div>
          <div id="soal-schedule-wrap" style="display:none">
            <label class="field-label">Waktu Rilis</label>
            <input type="datetime-local" id="soal-scheduled-time" class="field-input">
          </div>
          <div>
            <label class="field-label">Deadline</label>
            <input type="date" id="soal-due-date" class="field-input">
          </div>
          <div>
            <label class="field-label">Jam Deadline</label>
            <input type="time" id="soal-due-time" class="field-input" value="23:59">
          </div>
        </div>

        <div style="display:flex;gap:8px;justify-content:space-between;margin-top:4px">
          <button class="btn btn-ghost" onclick="resetImportSoal()">← Ganti JSON</button>
          <button class="btn btn-primary" id="soal-submit-btn" onclick="submitImportSoal()">
            🚀 Buat Google Form
          </button>
        </div>
      </div>

      <!-- Step 3: Hasil -->
      <div id="import-step-3" style="display:none">
        <div id="soal-result-box"></div>
      </div>

    </div>
  </div>
</div>

<!-- MODAL: Remote Wipe Konfirmasi -->
<div class="modal-overlay" id="modal-wipe">
  <div class="modal" style="max-width:460px">
    <div class="modal-head">
      <div class="modal-title">⚠️ Remote Wipe</div>
      <button class="modal-close" onclick="closeModal('modal-wipe')">×</button>
    </div>
    <div class="modal-body">
      <!-- Info perangkat -->
      <div style="padding:10px 12px;background:var(--surface2);border:1px solid var(--border);border-radius:8px;margin-bottom:14px;font-size:12.5px">
        Perangkat: <strong id="wipe-device-name">-</strong><br>
        User: <strong id="wipe-user-email">-</strong>
      </div>

      <!-- Pilih tipe wipe -->
      <div style="margin-bottom:14px">
        <label class="field-label">Tipe Wipe</label>
        <div style="display:flex;flex-direction:column;gap:8px;margin-top:6px">
          <label style="display:flex;align-items:flex-start;gap:10px;cursor:pointer;padding:10px 12px;border:1.5px solid var(--border);border-radius:8px" id="wipe-opt-account">
            <input type="radio" name="wipe-type" value="admin_account_wipe" checked onchange="updateWipeUI()">
            <div>
              <div style="font-size:13px;font-weight:500">Account Wipe</div>
              <div style="font-size:11.5px;color:var(--muted);margin-top:2px">Hanya menghapus akun sekolah dari perangkat. Data pribadi siswa tetap aman.</div>
            </div>
          </label>
          <label style="display:flex;align-items:flex-start;gap:10px;cursor:pointer;padding:10px 12px;border:1.5px solid var(--border);border-radius:8px" id="wipe-opt-full">
            <input type="radio" name="wipe-type" value="admin_remote_wipe" onchange="updateWipeUI()">
            <div>
              <div style="font-size:13px;font-weight:500;color:var(--red)">Full Wipe (Reset Pabrik)</div>
              <div style="font-size:11.5px;color:var(--muted);margin-top:2px">Menghapus SELURUH data perangkat termasuk foto, aplikasi, dan data pribadi. Tidak bisa dibatalkan!</div>
            </div>
          </label>
        </div>
      </div>

      <!-- Warning box — berubah sesuai pilihan -->
      <div id="wipe-warning-box" style="padding:10px 12px;background:var(--accent-lt);border:1px solid rgba(26,110,250,.2);border-radius:8px;margin-bottom:14px;font-size:12px;color:var(--accent-dk)">
        Akun sekolah akan dihapus dari perangkat. Data pribadi siswa tidak tersentuh.
      </div>

      <!-- Konfirmasi teks -->
      <div>
        <label class="field-label">Ketik <strong id="wipe-confirm-word">HAPUS AKUN</strong> untuk konfirmasi</label>
        <input type="text" id="wipe-confirm-input" class="field-input"
          placeholder="Ketik kata konfirmasi..."
          oninput="checkWipeConfirm()">
      </div>
      <input type="hidden" id="wipe-resource-id">
    </div>
    <div class="modal-footer">
      <button class="btn btn-ghost" onclick="closeModal('modal-wipe')">Batal</button>
      <button class="btn btn-danger" id="wipe-submit-btn" onclick="executeWipe()" disabled
        style="background:var(--red);color:#fff;border-color:var(--red)">
        🗑 <span id="wipe-btn-label">Wipe Akun Sekolah</span>
      </button>
    </div>
  </div>
</div>

<!-- MODAL: Essay Review -->
